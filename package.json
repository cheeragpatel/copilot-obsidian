{
  "name": "copilot-obsidian",
  "version": "0.1.0",
  "description": "GitHub Copilot integration for Obsidian using the official Copilot SDK",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": ["obsidian", "copilot", "github", "ai", "chat"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "@github/copilot-sdk": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "remark-gfm": "^4.0.1",
    "zod": "^3.23.0",
    "zustand": "^5.0.3"
  }
}
